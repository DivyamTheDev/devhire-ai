<div class="row mt-4">
    <div class="col-md-10 m-auto">
        <h2 class="mb-4">Available Job Openings</h2>
        
        <%- include('./partials/messages') %>

        <% if (jobs.length > 0) { %>
            <div class="row row-cols-1 g-4">
                <% jobs.forEach(job => { %>
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h5 class="card-title text-primary"><%= job.title %></h5>
                                        <h6 class="card-subtitle mb-2 text-muted"><%= job.company %></h6>
                                    </div>
                                    <span class="badge bg-light text-dark"><%= job.experienceRequired %> exp</span>
                                </div>
                                <p class="card-text mt-3"><%= job.description %></p>
                                <div class="mb-3">
                                    <strong>Skills Required:</strong><br>
                                    <% job.skillsRequired.forEach(skill => { %>
                                        <span class="badge bg-info text-dark me-1"><%= skill %></span>
                                    <% }); %>
                                </div>
                                <% if (user && user.role === 'developer') { %>
                                    <form action="/developer/apply/<%= job._id %>" method="POST">
                                        <button type="submit" class="btn btn-primary">Apply Now</button>
                                    </form>
                                <% } %>
                            </div>
                            <div class="card-footer text-muted small">
                                Posted on <%= job.createdAt.toDateString() %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="text-center mt-5">
                <p class="lead">No jobs available at the moment. Check back later!</p>
            </div>
        <% } %>
    </div>
</div>
